<ModelBehaviors>
    <Template Name="FBW_AIRBUS_Efis_Control_Template">
        <DefaultTemplateParameters>
            <ID>1</ID>
            <SIDE>L</SIDE>
        </DefaultTemplateParameters>

        <Component ID="EFIS_#SIDE#">
            <UseTemplate Name="FBW_Airbus_FCU_Button">
                <NODE_ID>PUSH_AUTOPILOT_FD_#SIDE#</NODE_ID>
                <HELPID>HELPID_AUTOPILOT_FLIGHT_DIRECTOR_SWITCH</HELPID>
                <SEQ1_CODE>(L:A32NX_FCU_#SIDE#_FD_LIGHT_ON, boolean)</SEQ1_CODE>
                <LEFT_SINGLE_CODE>(&gt;H:A32NX_FCU_FD_PUSH:#ID#)</LEFT_SINGLE_CODE>
            </UseTemplate>

            <UseTemplate Name="FBW_Airbus_FCU_Button">
                <NODE_ID>PUSH_AUTOPILOT_LS_#SIDE#</NODE_ID>
                <SEQ1_CODE>(L:A32NX_FCU_#SIDE#_LS_LIGHT_ON, boolean)</SEQ1_CODE>
                <LEFT_SINGLE_CODE>(&gt;H:A32NX_FCU_LS_PUSH:#ID#)</LEFT_SINGLE_CODE>
            </UseTemplate>

            <UseTemplate Name="FBW_Airbus_EFIS_FILTER_Button">
                <BASE_NAME>CSTR</BASE_NAME>
                <OPTION_ID_1>1</OPTION_ID_1>
                <OPTION_ID_2>6</OPTION_ID_2>
            </UseTemplate>

            <UseTemplate Name="FBW_Airbus_EFIS_FILTER_Button">
                <BASE_NAME>WPT</BASE_NAME>
                <OPTION_ID_1>2</OPTION_ID_1>
                <OPTION_ID_2>7</OPTION_ID_2>
            </UseTemplate>

            <UseTemplate Name="FBW_Airbus_EFIS_FILTER_Button">
                <BASE_NAME>VORD</BASE_NAME>
                <OPTION_ID_1>3</OPTION_ID_1>
                <OPTION_ID_2>8</OPTION_ID_2>
            </UseTemplate>

            <UseTemplate Name="FBW_Airbus_EFIS_FILTER_Button">
                <BASE_NAME>NDB</BASE_NAME>
                <OPTION_ID_1>4</OPTION_ID_1>
                <OPTION_ID_2>9</OPTION_ID_2>
            </UseTemplate>

            <UseTemplate Name="FBW_Airbus_EFIS_FILTER_Button">
                <BASE_NAME>ARPT</BASE_NAME>
                <OPTION_ID_1>5</OPTION_ID_1>
                <OPTION_ID_2>10</OPTION_ID_2>
            </UseTemplate>

            <UseTemplate Name="FBW_Airbus_EFIS_Range_Knob" />

            <UseTemplate Name="FBW_Airbus_EFIS_Mode_Knob" />

            <UseTemplate Name="FBW_Airbus_EFIS_Navaid_Switch">
                <INDEX>1</INDEX>
            </UseTemplate>
            <UseTemplate Name="FBW_Airbus_EFIS_Navaid_Switch">
                <INDEX>2</INDEX>
            </UseTemplate>

            <UseTemplate Name="FBW_Airbus_EFIS_Baro_Unit_Knob" />

            <UseTemplate Name="FBW_Airbus_EFIS_Baro_Knob_Template" />
        </Component>
    </Template>

    <Template Name="FBW_Airbus_EFIS_Baro_Knob_Template">
        <DefaultTemplateParameters>
            <NODE_ID>KNOB_AUTOPILOT_KNOB1_#SIDE#</NODE_ID>
            <ANIM_NAME_KNOB>KNOB_AUTOPILOT_KNOB1_#SIDE#</ANIM_NAME_KNOB>
            <ANIM_NAME_PUSHPULL>PUSH_AUTOPILOT_KNOB1_#SIDE#</ANIM_NAME_PUSHPULL>
            <ANIMREF_ID>-1</ANIMREF_ID>
            <ANIMTIP_0>TT:COCKPIT.TOOLTIPS.AUTOPILOT_PANEL_BARO_KNOB_INCREASE</ANIMTIP_0>
            <ANIMTIP_0_ON_CURSOR>TurnRight</ANIMTIP_0_ON_CURSOR>
            <ANIMTIP_1>TT:COCKPIT.TOOLTIPS.AUTOPILOT_PANEL_BARO_KNOB_DECREASE</ANIMTIP_1>
            <ANIMTIP_1_ON_CURSOR>TurnLeft</ANIMTIP_1_ON_CURSOR>
            <ANIMTIP_2>TT:COCKPIT.TOOLTIPS.BARO_REF_SET_STD</ANIMTIP_2>
            <ANIMTIP_2_ON_CURSOR>DownArrow</ANIMTIP_2_ON_CURSOR>
            <ANIMTIP_3>TT:COCKPIT.TOOLTIPS.BARO_ENABLE_SELECTION</ANIMTIP_3>
            <ANIMTIP_3_ON_CURSOR>UpArrow</ANIMTIP_3_ON_CURSOR>
            <PART_ID>AUTOPILOT_Knob_Baro</PART_ID>
        </DefaultTemplateParameters>

        <Component ID="#NODE_ID#" Node="#NODE_ID#">
            <UseTemplate Name="ASOBO_GT_Knob_Infinite_PushPull">
                <ANTICLOCKWISE_CODE>
                   (&gt;H:A32NX_FCU_BARO_DEC:#ID#)
                </ANTICLOCKWISE_CODE>

                <CLOCKWISE_CODE>
                    (&gt;H:A32NX_FCU_BARO_INC:#ID#)
                </CLOCKWISE_CODE>

                <PULL_CODE>
                    (&gt;H:A32NX_FCU_BARO_PULL:#ID#)
                </PULL_CODE>
                <PUSH_CODE>
                    (&gt;H:A32NX_FCU_BARO_PUSH:#ID#)
                </PUSH_CODE>

                <CENTER_RADIUS>0</CENTER_RADIUS>
                <COUNT>36</COUNT>
                <WWISE_EVENT>QNHknob</WWISE_EVENT>
                <WWISE_EVENT_1>QNHknob</WWISE_EVENT_1>
                <WWISE_EVENT_2>QNHknob</WWISE_EVENT_2>
            </UseTemplate>
            <!--Disables FCU baro knob emissive-->
            <UseTemplate Name="ASOBO_GT_Emissive_Gauge">
            </UseTemplate>
        </Component>
    </Template>

    <Template Name="FBW_Airbus_EFIS_Baro_Unit_Knob">
        <DefaultTemplateParameters>
            <NODE_ID>KNOB_AUTOPILOT_SELECTOR_#SIDE#1</NODE_ID>
            <ANIM_NAME>KNOB_AUTOPILOT_SELECTOR_#SIDE#1</ANIM_NAME>
            <WWISE_EVENT_1>lswitch</WWISE_EVENT_1>
            <WWISE_EVENT_2>lswitch</WWISE_EVENT_2>
            <ANIMTIP_0>TT:COCKPIT.TOOLTIPS.BARO_SET_UNIT_TO_HPA</ANIMTIP_0>
            <ANIMTIP_1>TT:COCKPIT.TOOLTIPS.BARO_SET_UNIT_TO_HG</ANIMTIP_1>
        </DefaultTemplateParameters>

        <Component ID="#NODE_ID#" Node="#NODE_ID#">
            <UseTemplate Name="ASOBO_GT_Switch_Code">
                <LEFT_SINGLE_CODE>(L:A32NX_FCU_#SIDE#_BARO_UNIT_KNOB_POS) ! (&gt;L:A32NX_FCU_#SIDE#_BARO_UNIT_KNOB_POS)</LEFT_SINGLE_CODE>
                <ANIM_CODE>(L:A32NX_FCU_#SIDE#_BARO_UNIT_KNOB_POS) 100 *</ANIM_CODE>
            </UseTemplate>
        </Component>
    </Template>

    <Template Name="FBW_Airbus_EFIS_Range_Knob">
        <Component ID="KNOB_AUTOPILOT_#SIDE#1" Node="KNOB_AUTOPILOT_#SIDE#1">
            <UseTemplate Name="ASOBO_GT_Switch_XStates">
                <ANIM_NAME>KNOB_AUTOPILOT_#SIDE#1</ANIM_NAME>
                <PART_ID>AIRLINER_Knob_Autopilot_ND_Range</PART_ID>
                <WWISE_EVENT>turnknob</WWISE_EVENT>
                <ANIMTIP_0_ON_PERCENT>0</ANIMTIP_0_ON_PERCENT>
                <ANIMTIP_1_ON_PERCENT>.2</ANIMTIP_1_ON_PERCENT>
                <ANIMTIP_2_ON_PERCENT>.4</ANIMTIP_2_ON_PERCENT>
                <ANIMTIP_3_ON_PERCENT>.6</ANIMTIP_3_ON_PERCENT>
                <ANIMTIP_4_ON_PERCENT>.8</ANIMTIP_4_ON_PERCENT>
                <ANIMTIP_5_ON_PERCENT>1</ANIMTIP_5_ON_PERCENT>
                <ANIMTIP_0>TT:COCKPIT.TOOLTIPS.EFIS_PANEL_RANGE_SELECTOR_SET_10</ANIMTIP_0>
                <ANIMTIP_1>TT:COCKPIT.TOOLTIPS.EFIS_PANEL_RANGE_SELECTOR_SET_20</ANIMTIP_1>
                <ANIMTIP_2>TT:COCKPIT.TOOLTIPS.EFIS_PANEL_RANGE_SELECTOR_SET_40</ANIMTIP_2>
                <ANIMTIP_3>TT:COCKPIT.TOOLTIPS.EFIS_PANEL_RANGE_SELECTOR_SET_80</ANIMTIP_3>
                <ANIMTIP_4>TT:COCKPIT.TOOLTIPS.EFIS_PANEL_RANGE_SELECTOR_SET_160</ANIMTIP_4>
                <ANIMTIP_5>TT:COCKPIT.TOOLTIPS.EFIS_PANEL_RANGE_SELECTOR_SET_320</ANIMTIP_5>
                <ANIMREF_ID>0</ANIMREF_ID>
                <ANIMCURSOR_MAX>1</ANIMCURSOR_MAX>

                <NUM_STATES>6</NUM_STATES>
                <SWITCH_DIRECTION>Horizontal</SWITCH_DIRECTION>
                <ARROW_TYPE>Curved</ARROW_TYPE>
                <SWITCH_POSITION_TYPE>L</SWITCH_POSITION_TYPE>
                <SWITCH_POSITION_VAR>A32NX_FCU_#SIDE#_RANGE_KNOB_POS</SWITCH_POSITION_VAR>
            </UseTemplate>
        </Component>
    </Template>

    <Template Name="FBW_Airbus_EFIS_Mode_Knob">
        <Component ID="KNOB_AUTOPILOT_ROSE_#SIDE#" Node="KNOB_AUTOPILOT_ROSE_#SIDE#">
            <UseTemplate Name="ASOBO_GT_Switch_5States">
                <Switch Param="SIDE">
                    <Case Value="L">
                        <ANIM_NAME>KNOB_AUTOPILOT_ROSE_L_</ANIM_NAME>
                    </Case>
                    <Case Value="R">
                        <ANIM_NAME>KNOB_AUTOPILOT_ROSE_R</ANIM_NAME>
                    </Case>
                </Switch>
                <PART_ID>KNOB_AUTOPILOT_ROSE_#SIDE#</PART_ID>
                <WWISE_EVENT>turnknob</WWISE_EVENT>
                <NORMALIZED_TIME_1>0.1</NORMALIZED_TIME_1>
                <NORMALIZED_TIME_2>0.5</NORMALIZED_TIME_2>
                <ANIMTIP_0_ON_PERCENT>0</ANIMTIP_0_ON_PERCENT>
                <ANIMTIP_1_ON_PERCENT>.25</ANIMTIP_1_ON_PERCENT>
                <ANIMTIP_2_ON_PERCENT>.5</ANIMTIP_2_ON_PERCENT>
                <ANIMTIP_3_ON_PERCENT>.75</ANIMTIP_3_ON_PERCENT>
                <ANIMTIP_4_ON_PERCENT>1</ANIMTIP_4_ON_PERCENT>
                <ANIMTIP_0>TT:COCKPIT.TOOLTIPS.EFIS_PANEL_MODE_SELECTOR_ROSE_LS</ANIMTIP_0>
                <ANIMTIP_1>TT:COCKPIT.TOOLTIPS.EFIS_PANEL_MODE_SELECTOR_ROSE_VOR</ANIMTIP_1>
                <ANIMTIP_2>TT:COCKPIT.TOOLTIPS.EFIS_PANEL_MODE_SELECTOR_ROSE_NAV</ANIMTIP_2>
                <ANIMTIP_3>TT:COCKPIT.TOOLTIPS.EFIS_PANEL_MODE_SELECTOR_ARC</ANIMTIP_3>
                <ANIMTIP_4>TT:COCKPIT.TOOLTIPS.EFIS_PANEL_MODE_SELECTOR_PLAN</ANIMTIP_4>
                <ANIMREF_ID>0</ANIMREF_ID>
                <ANIMCURSOR_MAX>1</ANIMCURSOR_MAX>
                <SWITCH_DIRECTION>Horizontal</SWITCH_DIRECTION>
                <ARROW_TYPE>Curved</ARROW_TYPE>
                <SWITCH_POSITION_TYPE>L</SWITCH_POSITION_TYPE>
                <SWITCH_POSITION_VAR>A32NX_FCU_#SIDE#_MODE_KNOB_POS</SWITCH_POSITION_VAR>
            </UseTemplate>
        </Component>
    </Template>

    <Template Name="FBW_Airbus_EFIS_Navaid_Switch">
        <DefaultTemplateParameters>
            <ANIM_NAME>SWITCH_AUTOPILOT_ADF#INDEX#_#SIDE#</ANIM_NAME>
            <NODE_ID>SWITCH_AUTOPILOT_ADF#INDEX#_#SIDE#</NODE_ID>
            <PART_ID>SWITCH_AUTOPILOT_ADF#INDEX#_#SIDE#</PART_ID>
            <WWISE_EVENT>lswitch</WWISE_EVENT>

            <ANIMREF_ID>0</ANIMREF_ID>
            <ANIMCURSOR_MAX>1</ANIMCURSOR_MAX>
            <STATE_VAR_NAME>A32NX_FCU_#SIDE#_NAVAID_#INDEX#_SWITCH_POS</STATE_VAR_NAME>
            <ANIMTIP_0>TT:COCKPIT.TOOLTIPS.EFIS_PANEL_ADFSWITCH_ADF#INDEX#</ANIMTIP_0>
            <ANIMTIP_1>TT:COCKPIT.TOOLTIPS.EFIS_PANEL_ADFSWITCH_OFF#INDEX#</ANIMTIP_1>
            <ANIMTIP_2>TT:COCKPIT.TOOLTIPS.EFIS_PANEL_ADFSWITCH_VOR#INDEX#</ANIMTIP_2>
            <ANIMTIP_0_ON_PERCENT>0</ANIMTIP_0_ON_PERCENT>
            <ANIMTIP_1_ON_PERCENT>.5</ANIMTIP_1_ON_PERCENT>
            <ANIMTIP_2_ON_PERCENT>1</ANIMTIP_2_ON_PERCENT>
        </DefaultTemplateParameters>

        <Component ID="#NODE_ID#" Node="#NODE_ID#">
            <UseTemplate Name="ASOBO_GT_Switch_3States">
                <SWITCH_DIRECTION>Horizontal</SWITCH_DIRECTION>
                <CODE_POS_0>
                (* LEFT *)
                1 (&gt;L:#STATE_VAR_NAME#)
                </CODE_POS_0>
                <CODE_POS_1>
                (* OFF *)
                0 (&gt;L:#STATE_VAR_NAME#)
                </CODE_POS_1>
                <CODE_POS_2>
                (* RIGHT *)
                2 (&gt;L:#STATE_VAR_NAME#)
                </CODE_POS_2>
                <STATE0_TEST>(L:#STATE_VAR_NAME#) 1 ==</STATE0_TEST>
                <STATE1_TEST>(L:#STATE_VAR_NAME#) 0 ==</STATE1_TEST>
                <STATE2_TEST>(L:#STATE_VAR_NAME#) 2 ==</STATE2_TEST>
            </UseTemplate>
        </Component>
    </Template>

    <Template Name="FBW_Airbus_EFIS_FILTER_Button">
        <DefaultTemplateParameters>
            <Switch Param="ID">
                <Case Value="1">
                    <EVENT_ID>#OPTION_ID_1#</EVENT_ID>
                </Case>
                <Case Value="2">
                    <EVENT_ID>#OPTION_ID_2#</EVENT_ID>
                </Case>
            </Switch>
            <TOOLTIPID>#BASE_NAME#</TOOLTIPID>
        </DefaultTemplateParameters>

        <UseTemplate Name="FBW_Airbus_FCU_Button">
            <NODE_ID>PUSH_AUTOPILOT_#BASE_NAME#_#SIDE#</NODE_ID>
            <SEQ1_CODE type="rnp" return="boolean">
                (L:A32NX_FCU_#SIDE#_#BASE_NAME#_LIGHT_ON, boolean)
            </SEQ1_CODE>
            <LEFT_SINGLE_CODE>
                (&gt;H:A32NX_FCU_FILTER_PUSH:#EVENT_ID#)
            </LEFT_SINGLE_CODE>
        </UseTemplate>
    </Template>

    <Template Name="FBW_AIRBUS_Push_EFIS_Button_Template">
        <DefaultTemplateParameters>
            <SIDE>L</SIDE>
            <NORMALIZED_TIME_1>0.1</NORMALIZED_TIME_1>
            <NORMALIZED_TIME_2>0.5</NORMALIZED_TIME_2>
            <ANIM_NAME>PUSH_AUTOPILOT_#BASE_NAME#_#SIDE#</ANIM_NAME>
            <NODE_ID>PUSH_AUTOPILOT_#BASE_NAME#_#SIDE#</NODE_ID>
            <INDICATOR_CODE>0</INDICATOR_CODE>
            <INDICATOR_NODE_ID>PUSH_AUTOPILOT_#BASE_NAME#_#SIDE#_SEQ1</INDICATOR_NODE_ID>
            <BACKLIGHT_NODE_ID>PUSH_AUTOPILOT_#BASE_NAME#_#SIDE#_SEQ2</BACKLIGHT_NODE_ID>
            <INDICATOR_POWERED>(L:A32NX_ELEC_AC_ESS_SHED_BUS_IS_POWERED, Bool)</INDICATOR_POWERED>
            <BACKLIGHT_POWERED>(L:A32NX_ELEC_AC_1_BUS_IS_POWERED, Bool)</BACKLIGHT_POWERED>
            <BACKLIGHT_POTENTIOMETER>84</BACKLIGHT_POTENTIOMETER>
            <BUTTON_CODE></BUTTON_CODE>
            <WWISE_EVENT_1>fcubutton</WWISE_EVENT_1>
            <WWISE_EVENT_2>fcubutton</WWISE_EVENT_2>
            <TOOLTIPID>#BASE_NAME#</TOOLTIPID>
        </DefaultTemplateParameters>

        <Component ID="#NODE_ID#" Node="#NODE_ID#">
            <Component ID="#NODE_ID#_BUTTON" Node="#NODE_ID#">
                <UseTemplate Name="ASOBO_GT_Push_Button">
                    <LEFT_SINGLE_CODE type="rnp">
                        if #INDICATOR_POWERED, bool# {
                            #BUTTON_CODE#;
                        }
                    </LEFT_SINGLE_CODE>
                </UseTemplate>
            </Component>

            <Component ID="#INDICATOR_NODE_ID#" Node="#INDICATOR_NODE_ID#">
                <UseTemplate Name="ASOBO_GT_Emissive_Gauge">
                    <EMISSIVE_CODE type="rnp" return="number">
                        let indicatorActive = #INDICATOR_CODE, bool#;
                        let indicatorsPowered = #INDICATOR_POWERED, bool#;
                        alias annunciatorLight = (L:A32NX_OVHD_INTLT_ANN, number);
                        let emissiveDim = if annunciatorLight == 2 { 0.1 } else { 1 };
                        (if (indicatorActive or annunciatorLight == 0) and indicatorsPowered {
                            1 * emissiveDim
                        } else {
                            0
                        })
                    </EMISSIVE_CODE>
                </UseTemplate>
            </Component>

            <Component ID="#BACKLIGHT_NODE_ID#" Node="#BACKLIGHT_NODE_ID#">
                <UseTemplate Name="ASOBO_GT_Emissive_Gauge">
                    <EMISSIVE_CODE>
                        (A:LIGHT POTENTIOMETER:#BACKLIGHT_POTENTIOMETER#, Percent over 100) #BACKLIGHT_POWERED# *
                    </EMISSIVE_CODE>
                </UseTemplate>
            </Component>
        </Component>
    </Template>
</ModelBehaviors>
